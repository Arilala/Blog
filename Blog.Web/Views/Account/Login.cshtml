@model LoginViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Connexion";
}

<div class="flex min-h-screen items-center justify-center bg-gray-100 px-4">
    <div class="w-full max-w-md">
        <div class="rounded-xl bg-white p-8 shadow-lg">

            <div class="mb-8 text-center">
                <h1 class="text-3xl font-bold text-gray-800">
                    Connexion
                </h1>
                <p class="mt-2 text-gray-500">
                    Connectez-vous à votre compte
                </p>
            </div>

            <form asp-action="Login" method="post" class="space-y-6">

                <div asp-validation-summary="ModelOnly"
                     class="text-sm text-red-500">
                </div>

                <div>
                    <label asp-for="Username"
                           class="mb-2 block text-sm font-medium text-gray-700">
                        Email
                    </label>

                    <input asp-for="Username"
                           class="w-full rounded-lg border border-gray-300 px-4 py-3 transition outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500"
                           placeholder="nom@exemple.com" />

                    <span asp-validation-for="Username"
                          class="text-sm text-red-500"></span>
                </div>

                <div>
                    <label asp-for="Password"
                           class="mb-2 block text-sm font-medium text-gray-700">
                        Mot de passe
                    </label>

                    <input asp-for="Password"
                           type="password"
                           class="w-full rounded-lg border border-gray-300 px-4 py-3 transition outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500"
                           placeholder="********" />

                    <span asp-validation-for="Password"
                          class="text-sm text-red-500"></span>
                </div>

                <div class="flex items-center justify-between">
                   
                    <a href="#"
                       class="text-sm text-indigo-600 hover:text-indigo-500">
                        Mot de passe oublié ?
                    </a>
                </div>

                <button type="submit"
                        class="w-full rounded-lg bg-indigo-600 py-3 font-medium text-white transition hover:bg-indigo-700">
                    Se connecter
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}